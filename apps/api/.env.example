# Optional Supabase project URL. The API starts without this value.
SUPABASE_URL="http://127.0.0.1:54321"

# Direct Postgres connection string used by the backend for RLS-aware
# workspace queries. Local secret; do not expose to the frontend or commit a
# real value.
SUPABASE_DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Optional server-only Supabase service role key. Never expose this value to
# the frontend or commit a real value. The API starts without this value.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"

# Optional legacy HS256 JWT secret fallback for older Supabase projects.
# Prefer JWKS verification when available. Local secret; do not commit a real
# value.
SUPABASE_JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
