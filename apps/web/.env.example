# Optional public base URL for future browser requests to the FastAPI app.
# This value is exposed to browser code and must never contain a secret.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project values used by the browser Supabase client.
# These are public identifiers, not service-role secrets.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
