# ---------------------------------------------------------------------------
# Smart Expense - AI — monorepo .gitignore (Next.js, FastAPI/Python, Supabase,
# Spec-Kit, VS Code). .specify/, docs/, and supabase/migrations are tracked.
# ---------------------------------------------------------------------------

# --- Environment variables & secrets ---
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.cert
*.crt
*credentials*.json
secrets/

# --- Node / Next.js (apps/web) ---
node_modules/
.pnpm-store/
.next/
out/
build/
dist/
.turbo/
.vercel/
next-env.d.ts
*.tsbuildinfo
.eslintcache
.npm
.yarn/
.pnp.*
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# --- Python / FastAPI (apps/api) ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
htmlcov/
.coverage
.coverage.*
pip-wrap.log
celerybeat-schedule

# --- Supabase local dev (keep migrations & config tracked) ---
supabase/.branches/
supabase/.temp/
supabase/.env
!supabase/migrations/
!supabase/migrations/**

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE (VS Code) ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- Misc local artifacts ---
*.local
*.tmp
.cache/
tmp/
temp/

# --- Explicitly keep tracked (do not ignore) ---
!.specify/
!.specify/**
!docs/
!docs/**
